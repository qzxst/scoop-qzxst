{
    "version": "4.0.3-1",
    "description": "A dynamic programming language with a focus on simplicity and productivity.",
    "homepage": "https://rubyinstaller.org",
    "license": "BSD-3-Clause",
    "notes": "Install MSYS2 via 'scoop install msys2' and then run 'ridk install' to install the toolchain!",
    "suggest": {
        "MSYS2": "msys2"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/oneclick/rubyinstaller2/releases/download/RubyInstaller-4.0.3-1/rubyinstaller-4.0.3-1-x64.7z",
            "hash": "a4094317397511e09242be1c95b32c8700fe91ebca713fb4e190de595eea5699",
            "extract_dir": "rubyinstaller-4.0.3-1-x64"
        }
    },
    "post_install": "gem install rake",
    "env_add_path": [
        "bin",
        "gems\\bin"
    ],
    "env_set": {
        "GEM_HOME": "$dir\\gems",
        "GEM_PATH": "$dir\\gems"
    },
    "persist": "gems",
    "checkver": {
        "github": "https://github.com/oneclick/rubyinstaller2",
        "regex": "/releases/tag/RubyInstaller-([\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/oneclick/rubyinstaller2/releases/download/RubyInstaller-$version/rubyinstaller-$version-x64.7z",
                "hash": {
                    "url": "https://api.github.com/repos/oneclick/rubyinstaller2/releases/latest",
                    "jsonpath": "$.assets[?(@.name == 'rubyinstaller-$version-x64.7z')].digest",
                    "type": "sha256"
                },
                "extract_dir": "rubyinstaller-$version-x64"
            }
        }
    }
}

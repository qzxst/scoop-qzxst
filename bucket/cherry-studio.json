    "homepage": "https://cherry-ai.com",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.8.4/Cherry-Studio-1.8.4-x64-setup.exe#dl.7z",
            "hash": "sha512:e3f3351cef5ec23af5b7276388da799783076dcc83dac4ac71799427a8ab2196166648db1daa647a68ed2a690cfe5b21ec5150a4e480584f50e6eea5ec89eff4"
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.8.4/Cherry-Studio-1.8.4-arm64-setup.exe#dl.7z ",
            "hash": "sha512:e3f3351cef5ec23af5b7276388da799783076dcc83dac4ac71799427a8ab2196166648db1daa647a68ed2a690cfe5b21ec5150a4e480584f50e6eea5ec89eff4"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
    ],
    "bin": [
        "Cherry Studio.exe",
        "Cherry Studio",
        "--user-data-dir=\"$dir\\User Data\""
    ],
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio",
        "regex": "/CherryHQ/cherry-studio/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm).*?sha512:\\s+$base64"
        },
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#dl.7z "
            }
        }
    }
}

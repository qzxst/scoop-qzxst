        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.7.8/Cherry-Studio-1.7.8-arm64-setup.exe#dl.7z ",
            "hash": "sha512:0e99024a85d4bd28e2c9e4f211b56eb4702195536c0ea6089f5113086ed73999e79a990384318cf03b914494ef8584fe1b2aa08545be4c379506c8429a2b1595"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
    ],
    "bin": [
        "Cherry Studio.exe",
        "Cherry Studio",
        "--user-data-dir=\"$dir\\User Data\""
    ],
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio",
        "regex": "/CherryHQ/cherry-studio/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm).*?sha512:\\s+$base64"
        },
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#dl.7z "
            }
        }
    }
}

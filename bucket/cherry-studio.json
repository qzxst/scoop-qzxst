{
    "version": "1.6.1",
    "description": "支持多模型服务的 Windows/macOS GPT 客户端。",
    "homepage": "https://cherry-ai.com",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.6.1/Cherry-Studio-1.6.1-x64-setup.exe#dl.7z",
            "hash": "sha512:62b268f452459fdf37e9493bd986d5acddb1024853bb1ab4d5a67959b375da2986ae466eb654c37b1c20accc4df1e1305c98630c7e5eb6df62d3ece48b5e53ee"
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.6.1/Cherry-Studio-1.6.1-arm64-setup.exe#dl.7z ",
            "hash": "sha512:62b268f452459fdf37e9493bd986d5acddb1024853bb1ab4d5a67959b375da2986ae466eb654c37b1c20accc4df1e1305c98630c7e5eb6df62d3ece48b5e53ee"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
    ],
    "bin": [
        "Cherry Studio.exe",
        "Cherry Studio",
        "--user-data-dir=\"$dir\\User Data\""
    ],
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio",
        "regex": "/CherryHQ/cherry-studio/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm).*?sha512:\\s+$base64"
        },
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#dl.7z "
            }
        }
    }
}

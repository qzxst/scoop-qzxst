{
    "version": "1.6.5",
    "description": "支持多模型服务的 Windows/macOS GPT 客户端。",
    "homepage": "https://cherry-ai.com",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.6.5/Cherry-Studio-1.6.5-x64-setup.exe#dl.7z",
            "hash": "f8a4e724e65d5e22b39b75ee732c13dee34a34f9a2151f449eda92b48530203b"
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.6.5/Cherry-Studio-1.6.5-arm64-setup.exe#dl.7z ",
            "hash": "sha512:582bcce8c50a090b93dcef745c24f284470a195c5492b1e8479680b7a6a4a9ebf83ae53f85d4b0329275540337907cedf7ff5eb78e0c887593cf4f533d9ccb64"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
    ],
    "bin": [
        "Cherry Studio.exe",
        "Cherry Studio",
        "--user-data-dir=\"$dir\\User Data\""
    ],
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio",
        "regex": "/CherryHQ/cherry-studio/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm).*?sha512:\\s+$base64"
        },
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#dl.7z"
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#dl.7z "
            }
        }
    }
}
